Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^x-Data/ - [F,L,NC]
</IfModule>

<FilesMatch "\.(sql|txt|csv|pem)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
